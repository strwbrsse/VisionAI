{
  "expo": {
    "name": "TaskFlow",
    "slug": "TaskFlow",
    "version": "1.0.0",
    "orientation": "portrait",

    "plugins": ["expo-router", "expo-camera", "expo-splash-screen"],

    "android": {
      "permissions": ["CAMERA"]
    },

    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Camera access is required to take photos."
      }
    }
  }
}
